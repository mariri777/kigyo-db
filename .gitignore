# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# .env.local だけ ignore (秘匿値を入れる用)。
# .env.development / .env.production は非機密のデフォルト設定でコミット可。
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cloudflare / OpenNext / Wrangler
.open-next/
.wrangler/
.dev.vars

# scripts/seed/snapshots/ は db:seed-local 後の復元用 (db:snapshot ↔ db:restore)。
# 中身の *.json は git にコミットして永続化する(本番 cron はこれを参照せず JPX/Yahoo から再取得)。
scripts/seed/.jpx-cache.*
scripts/seed/*.sql

# docker-compose の bind mount 用ローカルディレクトリ
# (named volume を使う想定だが、誤って bind mount しても巻き込まれないよう保険)
.docker/

local/

# macOS
.DS_Store

# IDE
.vscode/
.idea/

tmp