# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cloudflare / OpenNext / Wrangler
.open-next/
.wrangler/
.dev.vars

# scripts/seed/ はローカル D1 初期化(pnpm db:seed-local)のスナップショット。
# 本番 cron はこれを参照せず JPX/Yahoo を毎回取得する。
# snapshot 自体は pnpm db:snapshot を任意のタイミングで叩いて更新する。
scripts/seed/.jpx-cache.*
scripts/seed/*.sql

# macOS
.DS_Store

# IDE
.vscode/
.idea/

tmp