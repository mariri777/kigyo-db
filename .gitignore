# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cloudflare / OpenNext / Wrangler
.open-next/
.wrangler/
.dev.vars

# seed の CSV はリポジトリにコミットしない。
# 本番 D1 を id の正本とし、ローカル / Actions で都度 refresh-csv → seed/sync-remote で再生成する。
scripts/seed/*.csv
scripts/seed/.jpx-cache.*
scripts/seed/*.sql

# macOS
.DS_Store

# IDE
.vscode/
.idea/

tmp